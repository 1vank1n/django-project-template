DEBUG=on
SECRET_KEY="{{ secret_key }}"
# DATABASE_URL=psql://postgres@localhost/postgres
DATABASE_URL=sqlite:///db.sqlite3
POSTGRES_HOST_AUTH_METHOD=trust

# Gunicorn
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=30

# Host port exposed by docker compose (container port stays 8000)
APP_PORT=8000

# Django-axes
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Security (applied only when DEBUG=off)
# SECURE_SSL_REDIRECT=on
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# S3 / S3-compatible storage (MinIO, R2, Backblaze, etc.)
# Set AWS_STORAGE_BUCKET_NAME to enable S3 for static and media files.
# If empty — Django uses local filesystem (static/, media/).
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=                 # custom endpoint for MinIO / R2 / etc.
# AWS_S3_CUSTOM_DOMAIN=                # public domain / CDN (e.g. cdn.example.com)
# AWS_QUERYSTRING_AUTH=off             # off = public URLs, on = signed URLs
